# ===================================
# NC BRAND TEXTILES - FRONTEND CONFIG
# ===================================
# Copy this file to .env and fill in your values

# === API Configuration (Required) ===
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=10000

# === RAZORPAY (Required for online payments) ===
# Get from: https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# === App Configuration ===
VITE_APP_NAME=NC Brand Textiles
VITE_APP_VERSION=1.0.0

# === Auth Token Keys ===
VITE_ACCESS_TOKEN_KEY=ncbrand_access_token
VITE_REFRESH_TOKEN_KEY=ncbrand_refresh_token
